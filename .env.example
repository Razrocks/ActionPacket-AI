# Copy to .env.local and fill in. Secrets are server-only (never NEXT_PUBLIC_*).

# Required — powers the AI analysis step.
ANTHROPIC_API_KEY=
# Optional — defaults to claude-opus-4-8. Set to claude-sonnet-4-6 to cut cost.
ANTHROPIC_MODEL=

# Optional — enables Google Drive filing + Sheets tracking.
# Without these, those steps are skipped and the packet + PDF are still produced.
# Run `npm run auth:google` once to mint the refresh token.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_SHEETS_ID=

# Local SQLite path (defaults to dev.db).
SQLITE_PATH=

# Public app URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
